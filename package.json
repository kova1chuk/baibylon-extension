{
  "name": "vocairo-extension",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:extension": "vite build",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint -c oxlint.json",
    "lint:fix": "oxlint -c oxlint.json --fix",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "check": "run-p typecheck lint format:check",
    "preview": "vite preview",
    "watch:extension": "vite build --watch",
    "setup:extension": "./scripts/dev.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.55.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recoil": "^0.7.7",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@nkzw/oxlint-config": "^1.0.1",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/chrome": "^0.0.263",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript/native-preview": "7.0.0-dev.20260302.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.8.3",
    "vite": "^7.1.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,mts}": [
      "oxlint -c oxlint.json --fix",
      "oxfmt --write"
    ]
  }
}
